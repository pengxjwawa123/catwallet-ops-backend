# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# 宿主机对外映射端口(容器内仍是 PORT 3000)。3000 被占用时改这里
APP_PORT=3001
# 前端管理界面对外端口(nginx 容器,浏览器访问 http://<host>:WEB_PORT/)
WEB_PORT=8080
CORS_ORIGIN=*

# ─── Database ────────────────────────────────────────────────────────────────────
# Matches prisma/schema.prisma datasource env("DATABASE_URL")
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL=postgresql://ops:ops@localhost:5432/catwallet_ops?schema=public

POSTGRES_USER=ops
POSTGRES_PASSWORD=ops
POSTGRES_DB=catwallet_ops

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────────
# Required — must be a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Optional — defaults: 15m / 7d (matches env.validation.ts)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Observability ───────────────────────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=

# ─── CatWallet i18n API ──────────────────────────────────────────────────────────
# Upstream i18n config service. The backend proxies all i18n requests here.
CATWALLET_API_BASE_URL=https://dev.api.catwallet.ai
# Long-lived service bearer token used to authenticate i18n config requests
CATWALLET_API_TOKEN=
