# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=test
PORT=3000
APP_PORT=3001
WEB_PORT=8080
CORS_ORIGIN=https://ops-test.catwallet.com

# ─── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ops_test:CHANGE_ME@db-test.catwallet.internal:5432/catwallet_ops_test?schema=public

POSTGRES_USER=ops_test
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=catwallet_ops_test

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-test.catwallet.internal:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Seed ────────────────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME

# ─── CatWallet i18n API ──────────────────────────────────────────────────────────
CATWALLET_API_BASE_URL=https://dev.api.catwallet.ai
# Deprecated for direct frontend calls; keep empty unless the backend proxy path is restored.
CATWALLET_API_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────────────
SENTRY_DSN=
